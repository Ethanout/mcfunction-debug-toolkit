{
  "schemaVersion": 1,
  "id": "mc-command-bridge",
  "version": "${version}",
  "name": "MCFunction Debug Toolkit",
  "description": "Debug commands and datapacks with concise #! directives, live diagnostics, input automation, screenshots, and optional MCP integration.",
  "authors": ["Ethanout"],
  "contact": {
    "sources": "https://github.com/Ethanout/mcfunction-debug-toolkit",
    "issues": "https://github.com/Ethanout/mcfunction-debug-toolkit/issues"
  },
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": ["dev.underline.mccommand.bridge.McCommandBridge"],
    "client": ["dev.underline.mccommand.bridge.client.McCommandClient"]
  },
  "mixins": [
    "mc-command-bridge.server.mixins.json",
    "mc-command-bridge.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": "26.2.x",
    "java": ">=25",
    "fabric-api": "*"
  }
}
